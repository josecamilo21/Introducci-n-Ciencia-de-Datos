00}\n","df_hr[\"Salario_USD\"] = df_hr[\"Departamento\"].map(salario_base) + (df_hr[\"Años_Experiencia\"] * 200) + np.random.normal(0, 500, n_empleados)\n","\n","#Inyectamos Outliers reales (CEOs con salarios exorbitantes)\n","outlier_idx_idx = df_hr[df_hr[\"Departamento\"] == \"Directivos\"].sample(5).index\n","df_hr.loc[outlier_idx_idx, \"Salario_USD\"] = [150000, 280000, 320000, 190000, 450000]\n","\n","df_hr[\"Salario_USD\"] = df_hr[\"Salario_USD\"].round(2)\n","\n","display(df_hr.head())\n","print(f\"\\nDataset generado con {df_hr.shape[0]} filas y {df_hr.shape[1]} columnas.\")"]},{"cell_type":"code","source":[],"metadata":{"id":"ScIvl6Rj437r"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["media_edad = df_hr[\"Edad\"].mean()\n","media_salario = df_hr[\"Salario_USD\"].mean()\n","\n","print(f\"La edad promedio de la empresa es: {media_edad:.1f} años\")\n","print(f\"El Salario promedio (media) es: ${media_salario:,.2f} USD\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"zIbLgDNCk8He","executionInfo":{"status":"ok","timestamp":1773243772084,"user_tz":300,"elapsed":16,"user":{"displayName":"JOSE CAMILO ZAMBRANO JAIMES","userId":"02656123592539483533"}},"outputId":"16b9945a-d9ac-480c-e788-7d1b15f5b8f1"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["La edad promedio de la empresa es: 34.4 años\n","El Salario promedio (media) es: $8,478.36 USD\n"]}]},{"cell_type":"markdown","source":["#2.2 La Mediana y la Trampa de los Outliers\n","\n","**Pregunta para la clase:** ¿Es el salario promedio de $8,300 USD representativo de lo que gana un empleado normal en TechCorp?\n","**L**"],"metadata":{"id":"bb4-sGowoyPp"}},{"cell_type":"code","source":["# #1. Calculos matematicos\n","media_salario = df_hr[\"Salario_USD\"].mean()\n","mediana_salario = df_hr[\"Salario_USD\"].median()\n","\n","# Imprimimos la advertencia inicial\n","print(\"--- EL EFECTO GRAVEDAD DE LOS MILLONARIOS ---\")\n","print(f\"Media (Promedio Matemático): ${media_salario:,.2f} USD\")\n","print(f\"Mediana (El empleado del medio): ${mediana_salario:,.2f} USD\")\n","print(\"\\n¿Notas la diferencia? ¡El promedio es engañoso! Parece que todos ganan casi 9 mil dolares.\")\n","\n","# #2. Visualización Profesional\n","plt.figure(figsize=(14, 5))\n","\n","# Filtramos visualmente para que los CEOs no \"aplasten\" el gráfico\n","datos_visuales = df_hr[df_hr[\"Salario_USD\"] < 35000]\n","\n","# Dibujamos el histograma (Nota la coma y el signo = en line_kws)\n","sns.histplot(datos_visuales[\"Salario_USD\"], bins=40, color=\"skyblue\", kde=True,\n","             line_kws={\"linewidth\": 3, \"color\": \"navy\", \"alpha\": 0.8})\n","\n","# Dibujamos las lineas marcadas\n","plt.axvline(media_salario, color=\"red\", linestyle=\"dashed\", linewidth=3,\n","            label=f\"Media: ${media_salario:,.0f} (Jalada por los CEOs)\")\n","plt.axvline(mediana_salario, color=\"green\", linestyle=\"solid\", linewidth=3,\n","            label=f\"Mediana: ${mediana_salario:,.0f} (La realidad)\")\n","\n","plt.title(\"Distribución de Salarios: El choque entre la Media y la Mediana\", fontsize=15, fontweight=\"bold\")\n","plt.xlabel(\"Salario Mensual (USD)\")\n","plt.ylabel(\"Cantidad de Empleados\")\n","plt.xlim(0, 20000)\n","plt.ylim(0,110)\n","plt.legend(fontsize=12)\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":586},"id":"RvI5G29duG31","executionInfo":{"status":"ok","timestamp":1773243772845,"user_tz":300,"elapsed":746,"user":{"displayName":"JOSE CAMILO ZAMBRANO JAIMES","userId":"02656123592539483533"}},"outputId":"9745644a-99d0-4f27-88e6-bfbb8329e3fa"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["--- EL EFECTO GRAVEDAD DE LOS MILLONARIOS ---\n","Media (Promedio Matemático): $8,478.36 USD\n","Mediana (El empleado del medio): $6,801.10 USD\n","\n","¿Notas la diferencia? ¡El promedio es engañoso! Parece que todos ganan casi 9 mil dolares.\n"]},{"output_typ